# ================================
# IdlExplorer Configuration
# ================================

# Solana RPC endpoint for fetching on-chain IDLs
# Defaults to mainnet-beta public endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Devnet RPC
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Output directory for generated files
OUTPUT_DIR=./output

# Docs server port (for python main.py serve)
DOCS_PORT=8080

# Logging
LOG_LEVEL=INFO
